#!/bin/sh
# Auto-rebuild backend bundle if any backend source files changed

BACKEND_CHANGED=$(git diff --cached --name-only -- 'backend/*.ts' 'backend/routes/*.ts' 'backend/simulation/*.ts' 'backend/api/index.ts' | head -1)

if [ -n "$BACKEND_CHANGED" ]; then
  echo "Backend files changed — rebuilding api/index.js..."
  cd backend
  npx esbuild api/index.ts --bundle --platform=node --format=cjs --outfile=api/index.js --packages=external
  cd ..
  git add backend/api/index.js
  echo "✓ backend/api/index.js rebuilt and staged"
fi
